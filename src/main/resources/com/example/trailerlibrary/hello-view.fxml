<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.media.*?>

<BorderPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.memlibrary.HelloController">
    <center>
        <VBox alignment="CENTER" prefHeight="500" spacing="10" styleClass="center-panel">
            <Label styleClass="title-label" text="Бібліотека трейлерів" />

            <MediaView fx:id="mainMediaView" fitHeight="400" fitWidth="650" preserveRatio="true" styleClass="main-image" />

            <TextArea fx:id="descriptionArea" editable="false" prefHeight="600.0" prefWidth="650.0" wrapText="true" />

            <HBox alignment="CENTER" spacing="15">
                <Button fx:id="playButton" onAction="#playVideo" styleClass="play-button" text="Дивитись трейлер ▶" />
                <Button fx:id="pauseButton" onAction="#handlePause" styleClass="play-button" text="Пауза ⏸" />
            </HBox>
        </VBox>
    </center> <left>
    <ScrollPane fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" BorderPane.alignment="CENTER">
        <content>
            <VBox fx:id="iconContainer" alignment="TOP_CENTER" prefWidth="180" spacing="10" styleClass="left-panel" />
        </content>
    </ScrollPane>
</left>

</BorderPane>
