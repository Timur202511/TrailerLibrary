<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.memlibrary.HelloController"  stylesheets="@style.css">
    <left>
        <VBox fx:id="iconContainer" alignment="CENTER" prefWidth="150" spacing="10" styleClass="left-panel"/>
    </left>
    <center>
        <VBox alignment="CENTER" spacing="10" styleClass="center-panel">
            <Label text="Бібліотека мемів" styleClass="title-label"/>
            <ImageView fx:id="mainImageView" fitHeight="400" fitWidth="650" preserveRatio="true" styleClass="main-image"/>
            <TextArea fx:id="descriptionArea" editable="false" prefHeight="150" prefWidth="600" wrapText="true"/>
            <Button fx:id="playButton" onAction="#playAudio" text="Програти аудіо ▶" styleClass="play-button"/>
        </VBox>
    </center>

</BorderPane>
